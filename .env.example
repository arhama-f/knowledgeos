# ---- Backend (FastAPI) ----
ENVIRONMENT=development
LOG_LEVEL=INFO
SENTRY_DSN=

DATABASE_URL=postgresql+psycopg://knowledgeos:knowledgeos@localhost:5432/knowledgeos
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=knowledgeos
S3_SECRET_KEY=knowledgeos-dev-secret
S3_BUCKET=documents
S3_REGION=us-east-1
S3_USE_SSL=false

# Same Clerk application as the frontend below.
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_AUDIENCE=
CLERK_SECRET_KEY=sk_test_...

# AI — provider/model selection is config-driven; never hardcoded in code.
# llm provider/model: openai | anthropic | gemini
# embedding provider/model: openai | gemini (anthropic has no embeddings API)
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-6
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

CORS_ORIGINS=["http://localhost:3015"]

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/create-org
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_BASE_URL=http://localhost:3015

# ---- Production only (docker-compose.prod.yml) ----
# Must be set for the prod compose file — left blank here since dev doesn't need them.
POSTGRES_PASSWORD=
GHCR_IMAGE_PREFIX=
# e.g. ghcr.io/your-github-username/knowledgeos — must match what cd.yml pushes to.
DOMAIN=
# Your real domain (e.g. app.example.com) — Caddy auto-provisions HTTPS for it.
# Leave unset to serve plain HTTP on localhost for a local test of the prod stack.
FLOWER_BASIC_AUTH=
# user:password — protects the Celery monitoring dashboard.
BACKUP_RETENTION_COUNT=14
