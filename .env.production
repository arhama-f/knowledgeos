# ============================================================
# KnowledgeOS — production environment for knowledgeos.psychflo.com
# Copy this file to /root/knowledgeos/.env on your Hostinger VPS
# and fill in every blank value before running docker compose.
# ============================================================

# ---- Infrastructure ----
ENVIRONMENT=production
LOG_LEVEL=INFO
DOMAIN=knowledgeos.psychflo.com

# ---- Database ----
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql+psycopg://knowledgeos:CHANGE_ME_strong_password_here@postgres:5432/knowledgeos

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Object storage (MinIO — runs in Docker alongside the app) ----
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_access_key
S3_SECRET_KEY=CHANGE_ME_secret_key_min_16_chars
S3_BUCKET=documents
S3_REGION=us-east-1
S3_USE_SSL=false

# ---- Auth (JWT) ----
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_generate_a_64_byte_hex_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- AI providers ----
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-6
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=

# ---- CORS ----
CORS_ORIGINS=["https://knowledgeos.psychflo.com"]

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=KnowledgeOS <noreply@psychflo.com>
APP_URL=https://knowledgeos.psychflo.com

# ---- Frontend (baked into the Docker image at build time) ----
NEXT_PUBLIC_APP_URL=https://knowledgeos.psychflo.com
NEXT_PUBLIC_WISE_LINK_STARTER=https://wise.com/pay/r/A18ruSllGnsNqJU
NEXT_PUBLIC_WISE_LINK_BUSINESS=https://wise.com/pay/r/Nj-TAgLwXIGLTcs

# ---- Celery monitoring (Flower) ----
# Reach via: ssh -L 5555:localhost:5555 root@<vps-ip>  →  http://localhost:5555
FLOWER_BASIC_AUTH=admin:CHANGE_ME_flower_password

# ---- GitHub Container Registry (only needed for CI/CD pull deploys) ----
GHCR_IMAGE_PREFIX=
